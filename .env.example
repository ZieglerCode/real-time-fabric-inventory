# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase Configurations (Configured in Settings or .env)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only Supabase key for API routes that need to bypass RLS safely.
# Never expose this key in browser code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Comma-separated API keys for protected integration endpoints.
FABRIC_API_KEYS="replace-with-a-long-random-token"

# Optional public browser base URL used for QR lookup URLs.
NEXT_PUBLIC_APP_URL="https://fabric-inventory.example.com"
